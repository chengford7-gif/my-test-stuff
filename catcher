        return
    url = f"https://sctapi.ftqq.com/{sendkey}.send"
    data = {"title": title, "desp": content}
    try:
        res = requests.post(url, data=data, timeout=10)
        print(f"📲 微信推送响应结果: {res.text}")
    except Exception as e:
        print(f"❌ 微信推送失败: {e}")

