def get_macro_weekly_data(symbol):
    # ⚡ 抓取 3 年周线数据 (1w)，完美匹配原图宏观跨度
    url = f"https://query1.finance.yahoo.com/v8/finance/chart/{symbol}?range=3y&interval=1wk"
    headers = {'User-Agent': 'Mozilla/5.0'}
    try:
        response = requests.get(url, headers=headers, timeout=10)
        data = response.json()
        result = data['chart']['result'][0]
        df = pd.DataFrame({
            'date': pd.to_datetime(result['timestamp'], unit='s'),
            'high': result['indicators']['quote'][0]['high'],
            'low': result['indicators']['quote'][0]['low'],
            'close': result['indicators']['quote'][0]['close']
        })
        df.dropna(inplace=True)
        return df
    except Exception as e:
        print(f"❌ 宏观周线数据抓取失败: {e}")
        return None

def generate_tradingview_replica_chart(df, current_price):
    df = df.reset_index(drop=True)
    
    # 💥 创建高仿 TradingView 经典宽幅画布比例
    fig, ax = plt.subplots(figsize=(13, 7.5), facecolor='#ffffff')
    ax.set_facecolor('#ffffff')
    
    # 1. 开启对数坐标轴（TradingView 宏观划线核心）
    ax.set_yscale('log')
    
    # 💥 将纵轴刻度线移至右侧，实现 100% TradingView 视觉体验
    ax.yaxis.tick_right()
    ax.yaxis.set_label_position("right")
    
    # 2. 绘制历史真实收盘轨迹
    ax.plot(df['date'], df['close'], color='#4A525A', linewidth=1.5, label='IREN 1W (Real Close)', zorder=3)
    
    latest_date = df['date'].iloc[-1]
    
    # 3. 【时空安全锚点算法】锁定历史大级别宏观浪位
    w0_idx = 0
    w0_val = float(df['low'].iloc[0:15].min())
    
    # Wave 3 历史顶点 (精准锁定 2025 年末宏观高点)
    mask_2025 = (df['date'] >= '2025-09-01') & (df['date'] <= '2026-01-01')
    w3_idx = df[mask_2025]['high'].idxmax() if mask_2025.any() else df['high'].idxmax()
    w3_val = float(df['high'].iloc[w3_idx])
    w3_date = df['date'].iloc[w3_idx]
    
    # Wave 4 调整底 (锁定 Wave 3 之后的阶段大底)
    mask_2026 = (df['date'] > w3_date) & (df['date'] <= '2026-05-15')
    w4_idx = df[mask_2026]['low'].idxmin() if mask_2026.any() else w3_idx + 10
    w4_val = float(df['low'].iloc[w4_idx])
    w4_date = df['date'].iloc[w4_idx]
    
    # 4. 【Q-Structure $\lambda$ 射线矩阵随动重绘】
    future_weeks = 24
    forecast_dates = [latest_date + timedelta(weeks=i) for i in range(1, future_weeks + 1)]
    all_dates = list(df['date']) + forecast_dates
    x_coords = np.arange(len(all_dates))
    
    slope_base = (np.log(current_price) - np.log(w4_val)) / (len(df) - w4_idx) if len(df) > w4_idx else 0.02
    
    ray1_log = np.log(w4_val) + slope_base * 0.75 * (x_coords - w4_idx)
    ray2_log = np.log(w4_val) + slope_base * 1.25 * (x_coords - w4_idx)
    lambda_r_log = np.log(w0_val) + ((np.log(w3_val) - np.log(w0_val)) / w3_idx) * x_coords
    
    ax.plot(all_dates, np.exp(ray1_log), color='#8CA693', linestyle=':', linewidth=1.2, alpha=0.8, label='Q-Structure $\lambda_s$')
    ax.plot(all_dates, np.exp(ray2_log), color='#4A7355', linestyle='--', linewidth=1.2, alpha=0.7, label='Q-Structure $\lambda_1$')
    ax.plot(all_dates, np.exp(lambda_r_log), color='#A65B65', linestyle='-.', linewidth=1.2, alpha=0.6, label='Q-Structure $\lambda_r$')

    # 5. 【💥 核心修改：生成动态波浪轨迹函数并提取精确节点股价】
    hpq_target_val = 133.33  
    q_target_val = 249.99    
    
    idx_1 = int(len(forecast_dates) * 0.25)
    idx_2 = int(len(forecast_dates) * 0.50)
    
    w5_x = np.linspace(0, 1, len(forecast_dates))
    wave_profile = w5_x * 1.0 + 0.15 * np.sin(w5_x * np.pi * 2.5)  # 构建动态波动模型
    w5_path_log = np.log(current_price) + (np.log(hpq_target_val) - np.log(current_price)) * wave_profile
    w5_path = np.exp(w5_path_log)
    
    # 🎯 提取未来子浪节点的精确科学股价
    w1_price = float(w5_path[idx_1])
    w2_price = float(w5_path[idx_2])
    
    # 💥 用橙色虚线（Orange Dashed Line）渲染未来的五浪数浪投影
    ax.plot(forecast_dates, w5_path, color='#FF9800', linestyle='--', linewidth=2.5, label='Primary Wave ⑤ Projection', zorder=4)
    
    # 6. 时空汇聚预测蓝框
    box_start_dt = latest_date + timedelta(weeks=4)
    box_end_dt = latest_date + timedelta(weeks=16)
    ax.axvspan(box_start_dt, box_end_dt, ymin=0.62, ymax=0.92, color='#00E5FF', alpha=0.06)
    
    # 7. 【💥 核心修改：为所有浪位节点加上精确股价标注】
    # 历史节点标注（包含具体股价）
    ax.text(w3_date, w3_val * 1.08, f"③\n${w3_val:.2f}", color='#2B5E8C', fontsize=10, fontweight='bold', ha='center', va='bottom')
    ax.text(w4_date, w4_val * 0.92, f"④\n${w4_val:.2f}", color='#2B5E8C', fontsize=10, fontweight='bold', ha='center', va='top')
    
    # 预测子浪节点标注（包含具体股价）
    ax.text(forecast_dates[idx_1], w1_price * 1.08, f"(1)\n${w1_price:.2f}", color='#FF9800', fontsize=9, fontweight='bold', ha='center', va='bottom')
    ax.text(forecast_dates[idx_2], w2_price * 0.92, f"(2)\n${w2_price:.2f}", color='#FF9800', fontsize=9, fontweight='bold', ha='center', va='top')
    ax.text(forecast_dates[-1], hpq_target_val * 1.08, f"⑤\n(5)\n${hpq_target_val:.2f}", color='#2B5E8C', fontsize=11, fontweight='bold', ha='center', va='bottom')

    # 8. 右侧悬浮彩色价格电子标签
    x_edge = forecast_dates[-1] + timedelta(weeks=1)
    ax.text(x_edge, hpq_target_val, f" HPQ-Target: ${hpq_target_val} ", color='#ffffff', bbox=dict(facecolor='#00B0FF', edgecolor='none', boxstyle='square,pad=0.3'), fontsize=9, fontweight='bold', va='center')
    ax.text(x_edge, q_target_val, f" Q-Target: ${q_target_val} ", color='#ffffff', bbox=dict(facecolor='#2B5E8C', edgecolor='none', boxstyle='square,pad=0.3'), fontsize=9, fontweight='bold', va='center')
    ax.text(latest_date + timedelta(weeks=1), current_price, f" Now: ${current_price:.2f} ", color='#ffffff', bbox=dict(facecolor='#EB5757', edgecolor='none', boxstyle='square,pad=0.2'), fontsize=9, va='center')
    
    # 9. 网格及坐标轴区间美化
    ax.yaxis.set_major_formatter(ScalarFormatter())
    ax.grid(True, which="both", linestyle='--', color='#E5E8ED', alpha=0.5)
    
    ax.set_title(f'IREN LIMITED · 1W · NASDAQ — Quantum Model Projection', fontsize=12, fontweight='bold', loc='left', pad=12)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %y'))
    fig.autofmt_xdate()
    
    # 限制渲染视窗，完美给右侧预留空间
