def get_macro_weekly_data(symbol):
    # ⚡ 核心复刻：抓取 3 年的周线数据 (1w)，完美匹配原图的宏观时间跨度
    url = f"https://query1.finance.yahoo.com/v8/finance/chart/{symbol}?range=3y&interval=1wk"
    headers = {'User-Agent': 'Mozilla/5.0'}
    try:
        response = requests.get(url, headers=headers, timeout=10)
        data = response.json()
        result = data['chart']['result'][0]
        df = pd.DataFrame({
            'date': pd.to_datetime(result['timestamp'], unit='s'),
            'high': result['indicators']['quote'][0]['high'],
            'low': result['indicators']['quote'][0]['low'],
            'close': result['indicators']['quote'][0]['close']
        })
        df.dropna(inplace=True)
        return df
    except Exception as e:
        print(f"❌ 宏观周线数据抓取失败: {e}")
        return None

def generate_tradingview_replica_chart(df, current_price):
    df = df.reset_index(drop=True)
    
    # 💥 【视觉高度复刻】创建高仿 TradingView 经典比例画布
    fig, ax = plt.subplots(figsize=(13, 7.5), facecolor='#ffffff')
    ax.set_facecolor('#ffffff')
    
    # 1. 开启对数坐标轴（TradingView 宏观划线核心，完美复刻纵轴非线性刻度）
    ax.set_yscale('log')
    
    # 2. 绘制历史真实收盘轨迹（极简灰黑/深蓝 TradingView 风格线）
    ax.plot(df['date'], df['close'], color='#4A525A', linewidth=1.5, label='IREN 1W (Yahoo Finance)', zorder=3)
    
    latest_date = df['date'].iloc[-1]
    
    # 3. 【精准定位历史波浪锚点】根据原图历史特征自动捕捉或拟合宏观结构点
    # Wave 0 Bottom (~$1.02, Dec 2022)
    w0_idx = 0
    w0_val = float(df['low'].iloc[0:15].min())
    w0_date = df['date'].iloc[df['low'].iloc[0:15].idxmin()]
    
    # Wave 3 High (~$76.87, Nov 2025)
    w3_idx = df['high'].idxmax()
    w3_val = float(df['high'].max())
    w3_date = df['date'].iloc[w3_idx]
    
    # Wave 4 Bottom (~$30.76, 2026近期低点)
    w4_df = df.iloc[w3_idx:]
    w4_idx = w4_df['low'].idxmin()
    w4_val = float(w4_df['low'].min())
    w4_date = df['date'].iloc[w4_idx]
    
    # 4. 【Q-Structure $\lambda$ 几何发散射线动态重绘】
    future_weeks = 26
    forecast_dates = [latest_date + timedelta(weeks=i) for i in range(1, future_weeks + 1)]
    all_dates = list(df['date']) + forecast_dates
    x_coords = np.arange(len(all_dates))
    
    # 🔍 动态计算射线斜率：随当前最新价格实时调整切角！
    idx_w4_all = w4_idx
    slope_base = (np.log(current_price) - np.log(w4_val)) / (len(df) - idx_w4_all) if len(df) > idx_w4_all else 0.02
    
    # 完美的发散几何结构轨
    ray1_log = np.log(w4_val) + slope_base * 0.75 * (x_coords - idx_w4_all)
    ray2_log = np.log(w4_val) + slope_base * 1.25 * (x_coords - idx_w4_all)
    lambda_r_log = np.log(w0_val) + ((np.log(w3_val) - np.log(w0_val)) / w3_idx) * x_coords
    
    ax.plot(all_dates, np.exp(ray1_log), color='#8CA693', linestyle=':', linewidth=1.2, alpha=0.8, label='Q-Structure $\lambda_s$ (Ray 1)')
    ax.plot(all_dates, np.exp(ray2_log), color='#4A7355', linestyle='--', linewidth=1.2, alpha=0.7, label='Q-Structure $\lambda_1$ (Ray 2)')
    ax.plot(all_dates, np.exp(lambda_r_log), color='#A65B65', linestyle='-.', linewidth=1.2, alpha=0.6, label='Q-Structure $\lambda_r$')

    # 5. 【像素级复刻：未来五浪阶梯推动投影方向】
    # 原图蓝框内不是平滑曲线，而是明确的 (1)涨 -> (2)跌 -> (3)暴涨 -> (4)回撤 -> (5)见顶 阶梯路径！
    hpq_target_val = 133.33  # 核心模型第一目标
    q_target_val = 249.99    # 终极几何空间
    
    w5_x = np.linspace(0, 1, len(forecast_dates))
    # 构建波浪起伏因子
    wave_profile = w5_x * 1.0 + 0.15 * np.sin(w5_x * np.pi * 2.5)
    w5_path_log = np.log(current_price) + (np.log(hpq_target_val) - np.log(current_price)) * wave_profile
    w5_path = np.exp(w5_path_log)
    
    ax.plot(forecast_dates, w5_path, color='#00B0FF', linestyle='-', linewidth=2.5, label='Primary Wave ⑤ Projection', zorder=4)
    
    # 6. 【时空汇聚蓝区 (Convergence Zone)】
    box_start_dt = latest_date + timedelta(weeks=4)
    box_end_dt = latest_date + timedelta(weeks=16)
    ax.axvspan(box_start_dt, box_end_dt, ymin=0.65, ymax=0.92, color='#00E5FF', alpha=0.07, label='Quantum Convergence Block')
    
    # 7. 【历史传统浪位打标】
    ax.text(w3_date, w3_val * 1.15, "③", color='#2B5E8C', fontsize=12, fontweight='bold', ha='center')
    ax.text(w4_date, w4_val * 0.85, "④", color='#2B5E8C', fontsize=12, fontweight='bold', ha='center')
    
    # 🎯 预测浪位标签
    ax.text(forecast_dates[int(len(forecast_dates)*0.3)], w5_path[int(len(forecast_dates)*0.3)] * 1.15, "(1)", color='#00B0FF', fontsize=10)
    ax.text(forecast_dates[int(len(forecast_dates)*0.5)], w5_path[int(len(forecast_dates)*0.5)] * 0.88, "(2)", color='#00B0FF', fontsize=10)
    ax.text(forecast_dates[-1], hpq_target_val * 1.08, "⑤\n(5)", color='#2B5E8C', fontsize=11, fontweight='bold', ha='center')

    # 8. 【右侧 TradingView 悬浮价格标签】
    ax.text(forecast_dates[-1] + timedelta(weeks=2), hpq_target_val, f"HPQ-Target: ${hpq_target_val}", color='#ffffff', bg='#00B0FF', fontsize=9, fontweight='bold', va='center')
    ax.text(forecast_dates[-1] + timedelta(weeks=2), q_target_val, f"Q-Target: ${q_target_val}", color='#ffffff', bg='#2B5E8C', fontsize=9, fontweight='bold', va='center')
    ax.text(latest_date + timedelta(weeks=1), current_price, f"Now: ${current_price:.2f}", color='#ffffff', bg='#EB5757', fontsize=9, va='center')
    
    # 9. 纵轴坐标对数格式化美化（确保刻度线清晰美观）
    ax.yaxis.set_major_formatter(LogFormatterMatplotlib(labelOnlyBase=False, minor_thresholds=(2, 0.4)))
    ax.grid(True, which="both", linestyle='--', color='#E5E8ED', alpha=0.6)
    
    ax.set_title(f'IREN LIMITED · 1W · NASDAQ — Quantum Model Projection', fontsize=13, fontweight='bold', loc='left', pad=12)
    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %y'))
    fig.autofmt_xdate()
    
    # 限制渲染视窗，保证右侧标签展示完整
    ax.set_xlim(df['date'].iloc[w3_idx - 15], forecast_dates[-1] + timedelta(weeks=8))
    ax.set_ylim(w4_val * 0.5, q_target_val * 1.5)
    
    plt.savefig('iren_matrix.png', dpi=150, bbox_inches='tight')
    plt.close()
    return hpq_target_val, q_target_val, w4_val, w3_val

