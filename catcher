    ax.set_ylim(w4_val * 0.6, q_target_val * 1.4)
    
    # 💥 【彻底粉碎缓存】将图片保存在一个全新的文件名下
    plt.savefig('iren_quantum_v3.png', dpi=150, bbox_inches='tight')
    plt.close()
    return hpq_target_val, q_target_val, w4_val, w3_val

