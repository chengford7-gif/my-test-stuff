    # ---- 【主图：价格时空矩阵】 ----
    ax.set_facecolor('#ffffff')
    ax.set_yscale('log')
    ax.yaxis.tick_right()
    ax.yaxis.set_label_position("right")
    
    # 绘制历史真实价格轨迹
    ax.plot(df['date'], df['close'], color='#333333', linewidth=1.2, label='IREN 1W Close', zorder=3)
    
    latest_date = df['date'].iloc[-1]
    
    # 【时间窗口锁定】宏观 ③、④ 浪绝对锚点不动
    w0_idx = 0
    w0_val = float(df['low'].iloc[0:15].min())
    
    mask_2025 = (df['date'] >= '2025-09-01') & (df['date'] <= '2026-01-01')
    w3_idx = df[mask_2025]['high'].idxmax() if mask_2025.any() else df['high'].idxmax()
    w3_val = float(df['high'].iloc[w3_idx])
    w3_date = df['date'].iloc[w3_idx]
    
    mask_2026 = (df['date'] > w3_date) & (df['date'] <= '2026-05-15')
    w4_idx = df[mask_2026]['low'].idxmin() if mask_2026.any() else w3_idx + 10
    w4_val = float(df['low'].iloc[w4_idx])
    w4_date = df['date'].iloc[w4_idx]
    
    # 标注宏观大浪锚点价格
    ax.text(w3_date, w3_val * 1.08, f"③\n${w3_val:.2f}", color='#1A365D', fontsize=9, fontweight='bold', ha='center', va='bottom')
    ax.text(w4_date, w4_val * 0.92, f"④\n${w4_val:.2f}", color='#1A365D', fontsize=9, fontweight='bold', ha='center', va='top')

    # Q-Structure 经典纯细几何射线
    future_weeks = 24
    forecast_dates = [latest_date + timedelta(weeks=i) for i in range(0, future_weeks + 1)]
    all_dates = list(df['date']) + forecast_dates[1:]
    x_coords = np.arange(len(all_dates))
    
    slope_base = (np.log(current_price) - np.log(w4_val)) / (len(df) - w4_idx) if len(df) > w4_idx else 0.02
    ray1_log = np.log(w4_val) + slope_base * 0.75 * (x_coords - w4_idx)
    ray2_log = np.log(w4_val) + slope_base * 1.25 * (x_coords - w4_idx)
    lambda_r_log = np.log(w0_val) + ((np.log(w3_val) - np.log(w0_val)) / w3_idx) * x_coords
    
    ax.plot(all_dates, np.exp(ray1_log), color='#7F8C8D', linestyle=':', linewidth=1.0, alpha=0.7)
    ax.plot(all_dates, np.exp(ray2_log), color='#27AE60', linestyle='--', linewidth=1.0, alpha=0.6)
    ax.plot(all_dates, np.exp(lambda_r_log), color='#C0392B', linestyle='-.', linewidth=1.0, alpha=0.5)

