def get_historical_k_data(symbol):
    url = f"https://query1.finance.yahoo.com/v8/finance/chart/{symbol}?range=90d&interval=1d"
    headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)'}
    try:
        response = requests.get(url, headers=headers, timeout=10)
        data = response.json()
        result = data['chart']['result'][0]
        df = pd.DataFrame({
            'date': pd.to_datetime(result['timestamp'], unit='s'),
            'open': result['indicators']['quote'][0]['open'],
            'high': result['indicators']['quote'][0]['high'],
            'low': result['indicators']['quote'][0]['low'],
            'close': result['indicators']['quote'][0]['close'],
            'volume': result['indicators']['quote'][0]['volume']
        })
        df.dropna(inplace=True)
        return df
    except Exception as e:
        print(f"❌ 抓取 {symbol} 数据失败: {e}")
        return None

def find_recent_wave_bounds(df, window=5):
    df['is_local_max'] = df['high'] == df['high'].rolling(window=window*2+1, center=True).max()
    df['is_local_min'] = df['low'] == df['low'].rolling(window=window*2+1, center=True).min()
    local_maxima = df[df['is_local_max']].sort_values(by='date', ascending=False)
    local_minima = df[df['is_local_min']].sort_values(by='date', ascending=False)
    if local_maxima.empty or local_minima.empty:
        return float(df['high'].max()), float(df['low'].min())
    return float(local_maxima['high'].iloc[0]), float(local_minima['low'].iloc[0])

def generate_trend_and_forecast_chart(df, wave_high, fib_500, fib_618, hard_loss, tp2):
    plot_df = df.tail(60).copy()
    fig, ax = plt.subplots(figsize=(12, 6.5))
    
    # 1. 历史轨迹
    ax.plot(plot_df['date'], plot_df['close'], label='IREN Historical Close', color='#1f77b4', linewidth=2.5)
    
    latest_date = plot_df['date'].iloc[-1]
    latest_close = plot_df['close'].iloc[-1]
    ax.scatter(latest_date, latest_close, color='red', s=90, zorder=5)
    ax.text(latest_date, latest_close, f'  Current: ${latest_close:.2f}', color='red', fontweight='bold', va='center')

    # 2. 空间矩阵轨道
    ax.axhline(y=wave_high, color='orange', linestyle='--', alpha=0.6, label=f'TP1 / Wave 3 High (${wave_high:.2f})')
    ax.axhline(y=fib_500, color='gold', linestyle=':', alpha=0.5, label=f'Fib 50.0% Support (${fib_500:.2f})')
    ax.axhline(y=fib_618, color='g', linestyle=':', alpha=0.5, label=f'Fib 61.8% Entry Zone (${fib_618:.2f})')
    ax.axhline(y=hard_loss, color='r', linestyle='--', alpha=0.6, label=f'SL Hard Stop (${hard_loss:.2f})')
    ax.axhline(y=tp2, color='purple', linestyle='-.', alpha=0.7, label=f'TP2 Wave 5 Extension (${tp2:.2f})')
    
    ax.fill_between(plot_df['date'], fib_618, fib_500, color='green', alpha=0.06, label='Golden Entry Zone')
    
    # 🔮 3. 核心：构建未来五浪推动预测曲线
    forecast_dates = [latest_date + timedelta(days=i) for i in range(1, 16)]
    time_steps = np.linspace(0, 1, len(forecast_dates))
    forecast_path = latest_close + (tp2 - latest_close) * time_steps + 3 * np.sin(time_steps * np.pi * 1.5)
    
    ax.plot(forecast_dates, forecast_path, color='purple', linestyle=':', linewidth=2.5, label='⚡ Predicted Wave 5 Path')
    ax.scatter(forecast_dates[-1], forecast_path[-1], color='purple', marker='*', s=150, zorder=5)
    ax.text(forecast_dates[-1], forecast_path[-1], f'  Target: ${tp2:.2f}', color='purple', fontweight='bold', va='bottom')

    ax.set_title(f'{SYMBOL} Technical Matrix & Wave 5 Forecast Radar', fontsize=14, fontweight='bold', pad=15)
    ax.grid(True, linestyle='--', alpha=0.25)
    ax.legend(loc='upper left')
    fig.autofmt_xdate()
    
    plt.savefig('iren_matrix.png', dpi=150, bbox_inches='tight')
    plt.close()

def send_wechat_notification(title, content):
